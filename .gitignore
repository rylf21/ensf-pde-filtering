# Data and figures — generated by running notebooks, not tracked by git
data/*
figures/*
heat_equation/data/*
heat_equation/figures/*
allen_cahn/data/*
allen_cahn/figures/*

# Keep folder structure when cloning
!data/.gitkeep
!figures/.gitkeep
!heat_equation/data/.gitkeep
!heat_equation/figures/.gitkeep
!allen_cahn/data/.gitkeep
!allen_cahn/figures/.gitkeep

# Python
__pycache__/
*.py[cod]
*.pyo
.ipynb_checkpoints/

# Data file formats
*.h5
*.hdf5
*.npz
*.npy
*.xdmf
*.h5p
*.zip

# OS
.DS_Store
Thumbs.db
